PROJECT_NAME           = "GNC Viz"
PROJECT_NUMBER         = 1.0
PROJECT_BRIEF          = "Spacecraft GNC simulation data visualizer"
OUTPUT_DIRECTORY       = docs/generated
INPUT                  = include/gnc_viz src/lib src/app docs/pages README.md
FILE_PATTERNS          = *.hpp *.cpp *.mm *.md
RECURSIVE              = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
GENERATE_LATEX         = NO
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HAVE_DOT               = NO
USE_MDFILE_AS_MAINPAGE = README.md
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT
SORT_MEMBER_DOCS       = NO
SHOW_USED_FILES        = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCES_RELATION    = YES
VERBATIM_HEADERS       = YES
WARN_IF_UNDOCUMENTED   = YES
QUIET                  = NO
WARNINGS               = YES
WARN_NO_PARAMDOC       = YES
EXTENSION_MAPPING      = mm=C++
HTML_EXTRA_STYLESHEET  = docs/doxygen-awesome/doxygen-awesome.css \
                         docs/doxygen-awesome/doxygen-awesome-sidebar-only.css
HTML_EXTRA_FILES       = docs/doxygen-awesome/doxygen-awesome-darkmode-toggle.js
